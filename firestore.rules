rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para validar si el usuario es Gerente
    function isManager() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gerente';
    }

    // Función para validar si el usuario es Gerente o Coordinador/a
    function isManagerOrCoordinator() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gerente' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinador' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coordinadora');
    }

    // Función para obtener el área del usuario
    function getUserArea() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.area;
    }

    // 1. USUARIOS: Todos leen perfiles. El dueño o el Gerente pueden editar/borrar.
    match /users/{userId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid == userId || isManager();
    }

    // 2. PLANES DE ACCIÓN: Acceso abierto para lectura/creación.
    match /action_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow create: if request.auth.uid != null;
      // Edición
      allow update: if request.auth.uid == resource.data.creator_id || 
                    request.auth.uid == resource.data.lead_id || 
                    isManagerOrCoordinator();
      // Borrado
      allow delete: if isManager();
      
      // Historial
      match /history/{histId} {
        allow read, write: if request.auth.uid != null;
      }
    }

    // 3. TAREAS DE PROYECTO
    match /tasks/{taskId} {
      allow read: if request.auth.uid != null;
      allow create: if request.auth.uid != null && 
                    request.resource.data.plan_id != null &&
                    exists(/databases/$(database)/documents/action_plans/$(request.resource.data.plan_id)) &&
                    (
                      isManagerOrCoordinator() || 
                      get(/databases/$(database)/documents/action_plans/$(request.resource.data.plan_id)).data.lead_id == request.auth.uid ||
                      (get(/databases/$(database)/documents/action_plans/$(request.resource.data.plan_id)).data.members_ids != null &&
                       request.auth.uid in get(/databases/$(database)/documents/action_plans/$(request.resource.data.plan_id)).data.members_ids)
                    );
      allow update: if request.auth.uid != null &&
                    (
                      isManagerOrCoordinator() || 
                      request.auth.uid == resource.data.assigned_id ||
                      (resource.data.plan_id != null && 
                       exists(/databases/$(database)/documents/action_plans/$(resource.data.plan_id)) &&
                       get(/databases/$(database)/documents/action_plans/$(resource.data.plan_id)).data.lead_id == request.auth.uid)
                    );
      allow delete: if request.auth.uid != null &&
                    (
                      isManager() || 
                      request.auth.uid == resource.data.creator_id
                    );
      
      // Notas de seguimiento
      match /notes/{noteId} {
        allow read, write: if request.auth.uid != null;
      }
    }

    // 4. TAREAS PERSONALES
    match /personal_tasks/{taskId} {
      // Permitir todo a su dueño
      allow read, write: if request.auth.uid != null;
    }

    // 5. NOTIFICACIONES
    match /notifications/{notifId} {
      allow read, write: if request.auth.uid != null;
    }

    // 6. VACACIONES
    match /vacation_requests/{reqId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.uid != null;
    }

    // 7. KEEP NOTES
    match /keep_notes/{noteId} {
      allow read, write: if request.auth.uid != null;
    }
  }
}
